{
  "name": "@pocket-bxl/db",
  "type": "module",
  "exports": {
    ".": {
      "default": "./src/index.ts"
    },
    "./migrate": {
      "default": "./src/migrate.ts"
    },
    "./schema": {
      "default": "./src/schema/index.ts"
    },
    "./schema/auth": {
      "default": "./src/schema/auth.ts"
    },
    "./schema/gtfs": {
      "default": "./src/schema/gtfs.ts"
    },
    "./*": {
      "default": "./src/*.ts"
    }
  },
  "scripts": {
    "db:push": "drizzle-kit push",
    "db:generate": "drizzle-kit generate",
    "db:studio": "drizzle-kit studio",
    "db:migrate": "drizzle-kit migrate"
  },
  "dependencies": {
    "@pocket-bxl/env": "workspace:*",
    "dotenv": "catalog:",
    "drizzle-orm": "^0.45.1",
    "pg": "^8.17.1",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@pocket-bxl/config": "workspace:*",
    "@types/node": "^22.13.14",
    "@types/pg": "^8.16.0",
    "drizzle-kit": "^0.31.8",
    "typescript": "catalog:"
  }
}
